# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs
NEXT_PUBLIC_STRIPE_PLUS_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PLUS_YEARLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp bot (Sprint 11). Ships dark — both flags default false.
# Enable WHATSAPP_BOT_ENABLED once Twilio credentials are wired. Enable
# WHATSAPP_DEV_STUB ONLY in development: it skips X-Twilio-Signature
# validation so you can curl the webhook without a Twilio round-trip.
WHATSAPP_BOT_ENABLED=false
WHATSAPP_DEV_STUB=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Optional: exact public URL Twilio will POST to, used for signature
# verification. Defaults to request.url (fine on Vercel).
TWILIO_WEBHOOK_URL=

# AI voice extraction (Sprint 12). Ships dark; flag defaults false.
# Enable once both OPENAI_API_KEY (Whisper) and ANTHROPIC_API_KEY
# (Claude Haiku extraction) are populated. Also requires the Twilio
# credentials above to fetch the media payload back from Twilio.
WHATSAPP_VOICE_ENABLED=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Flight auto-match cron (Sprint 13). Ships dark; flag defaults false.
# FLIGHT_MATCH_CRON_SECRET is the bearer token the scheduler sends on
# POST /api/flights/poll. AVIATIONSTACK_ACCESS_KEY must be Starter tier
# or higher — the free tier caps at 100 calls/month which is too tight
# for a 15-minute cron covering LCA + PFO.
FLIGHT_MATCH_ENABLED=false
FLIGHT_MATCH_CRON_SECRET=
AVIATIONSTACK_ACCESS_KEY=

# JCC Payments (Sprint 16). Ships dark; flag defaults false.
# When JCC_ENABLED=true, every other JCC_* var becomes required — a
# missing one 503s the checkout route. JCC_RETURN_URL must exactly match
# whatever JCC registered as your callback URL (no trailing slash, no
# query string). JCC_GATEWAY_URL defaults to the sandbox endpoint; swap
# to the production URL JCC provides on go-live.
JCC_ENABLED=false
JCC_MER_ID=
JCC_ACQ_ID=
JCC_SECRET=
JCC_GATEWAY_URL=https://gateway-test.jcc.com.cy/payment/Payment
JCC_RETURN_URL=
